# Copy this file to ".env" and adjust as needed. ".env" is gitignored.
#
# IMPORTANT: .env is for the LOCAL DEV container and non-secret settings only.
# Your real provider API keys and your real database credentials live in the OS
# keychain, not here (security.md §1). The values below configure the throwaway
# Docker Postgres used while building Orrery.

# --- Local dev Postgres (read by docker-compose.yml) ---
POSTGRES_USER=orrery
POSTGRES_PASSWORD=orrery_dev_password
POSTGRES_DB=orrery
POSTGRES_PORT=5432

# --- The connection string the app uses on first run ---
# Matches the values above. On first launch Orrery offers to save this in the
# keychain so it isn't read from disk thereafter.
DATABASE_URL=postgresql+psycopg://orrery:orrery_dev_password@127.0.0.1:5432/orrery

# --- Dev toggles ---
# 0 = serve the built UI from ui/dist via FastAPI (single command: python app.py).
# 1 = point the desktop window at the Vite dev server (npm run dev) for hot reload.
ORRERY_DEV=0
