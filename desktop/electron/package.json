{
  "name": "orrery-desktop",
  "version": "0.1.3",
  "private": true,
  "description": "Electron shell for Orrery desktop.",
  "main": "main.cjs",
  "scripts": {
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  },
  "devDependencies": {
    "electron": "39.8.10",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.orrery.desktop",
    "productName": "Orrery",
    "artifactName": "Orrery-${version}-${os}-${arch}.${ext}",
    "files": [
      "main.cjs",
      "preload.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../../assets/desktop",
        "to": "assets/desktop"
      }
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "zaidt156",
        "repo": "Orrery"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "../../assets/desktop/orrery.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "../../assets/desktop/orrery.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
